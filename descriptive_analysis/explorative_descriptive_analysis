    "import pandas as pd\n",
    "import numpy as np\n",
    "import re\n",
    "from collections import Counter\n",
    "import spacy\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "from tqdm.notebook import tqdm_notebook\n",
    "\n",
    "tqdm_notebook.pandas()\n",
    "BATCH_SIZE = 64\n",
    "N_PROCESS = 1 \n",
    "\n",
    "#Load Data\n",
    "gender_df = pd.read_csv(\"../data/gender.csv\", encoding=\"utf-8\")\n",
    "scriptdata = pd.read_csv(\"../data/combine.csv\",encoding=\"utf-8\")\n",
    "speakers = pd.read_csv(\"../data/rolle.tsv\", encoding=\"utf-8\", delimiter=\"\\t\")\n",
    "additional_speakers= pd.read_csv(\"../data/additional_roles.csv\",encoding=\"utf-8\")\n",
    "\n",
    "speakers = (pd.concat([speakers, additional_speakers], ignore_index=True)\n",
    "              .drop_duplicates(subset=[\"name\"], keep=\"first\"))\n",
    "\n",
    "\n",
    "scriptdata = scriptdata[~scriptdata[\"Text\"].isna()]\n",
    "scriptdata = scriptdata[scriptdata[\"speaker_id\"] != 0]\n",
    "\n",
    "#merge gender and speaker\n",
    "speakers_with_gender = speakers.merge(gender_df, on=\"rolleID\", how=\"left\")\n",
    "\n",
    "scriptdata = scriptdata.merge(\n",
    "    speakers_with_gender[[\"rolleID\", \"gender\"]],\n",
    "    left_on=\"speaker_id\",\n",
    "    right_on=\"rolleID\",\n",
    "    how=\"left\"\n",
    ")\n",
    "\n",
    "#Delete lines, where gender is unknown\n",
    "scriptdata = scriptdata[scriptdata[\"gender\"].isin([\"m\", \"f\"])].copy()"
   ]
