    "# interaction-analysis; ai assisted\n",
    " \n",
    "interact_df = pd.read_csv(\"../data/combine.csv\", encoding=\"utf-8\")\n",
    "interact_df = interact_df[~interact_df[\"Text\"].isna()]\n",
    "interact_df = interact_df[interact_df[\"speaker_id\"] != 0]\n",
    " \n",
    "interact_df = interact_df.merge(\n",
    "    speakers_with_gender[[\"rolleID\", \"gender\"]],\n",
    "    left_on=\"speaker_id\", right_on=\"rolleID\", how=\"left\"\n",
    ")\n",
    "interact_df = interact_df[interact_df[\"gender\"].isin([\"m\", \"f\"])].copy()\n",
    " \n",
    "sort_cols = [\"Episode\", \"Page\"] if \"Page\" in interact_df.columns else [\"Episode\"]\n",
    "interact_df = interact_df.sort_values(sort_cols).reset_index(drop=True)\n",
    " \n",
    "interact_df[\"next_gender\"]  = interact_df[\"gender\"].shift(-1)\n",
    "interact_df[\"next_episode\"] = interact_df[\"Episode\"].shift(-1)\n",
    " \n",
    "interact_df = interact_df[\n",
    "    (interact_df[\"Episode\"] == interact_df[\"next_episode\"]) &\n",
    "    interact_df[\"next_gender\"].isin([\"m\", \"f\"])\n",
    "].copy()\n",
    " \n",
    "#matrix\n",
    "interaction_counts = (interact_df\n",
    "                      .groupby([\"gender\", \"next_gender\"])\n",
    "                      .size()\n",
    "                      .reset_index(name=\"count\"))\n",
    " \n",
    "matrix_abs = (interaction_counts\n",
    "              .pivot(index=\"gender\", columns=\"next_gender\", values=\"count\")\n",
    "              .fillna(0))\n",
    "matrix_abs.index   = [\"Männlich\" if g == \"m\" else \"Weiblich\" for g in matrix_abs.index]\n",
    "matrix_abs.columns = [\"→ Männlich\" if g == \"m\" else \"→ Weiblich\" for g in matrix_abs.columns]\n",
    " \n",
    "# matrix with relative values\n",
    "matrix_rel = matrix_abs.div(matrix_abs.sum(axis=1), axis=0)\n",
    " \n",
    "print(\"\\n── Absolute Interaktionen (Sprecher → nächster Sprecher) ──\")\n",
    "print(matrix_abs.to_string())\n",
    "print(\"\\n── Relative Interaktionen (Anteil je Sprecher-Geschlecht) ──\")\n",
    "print(matrix_rel.round(4).to_string())\n",
    " \n",
    "# Visualization\n",
    "fig4, axes4 = plt.subplots(1, 2, figsize=(18, 5))\n",
    "fig4.suptitle(\"Interaktionsanalyse\",\n",
    "              fontsize=15, fontweight=\"bold\")\n",
    " \n",
    "abs_vals = matrix_abs.values\n",
    "rel_vals = matrix_rel.values\n",
    "row_labels = list(matrix_abs.index)        \n",
    "col_labels = list(matrix_abs.columns)        \n",
    " \n",
    "# Heatmap\n",
    "ax = axes4[0]\n",
    "im = ax.imshow(abs_vals, cmap=\"Blues\", aspect=\"auto\")\n",
    "ax.set_xticks([0, 1]); ax.set_xticklabels(col_labels)\n",
    "ax.set_yticks([0, 1]); ax.set_yticklabels(row_labels)\n",
    "ax.set_xlabel(\"Nächster Sprecher\"); ax.set_ylabel(\"Sprecher\")\n",
    "ax.set_title(\"Absolute Häufigkeit\")\n",
    "for i in range(2):\n",
    "    for j in range(2):\n",
    "        color = \"white\" if abs_vals[i, j] > abs_vals.max() * 0.6 else \"black\"\n",
    "        ax.text(j, i, f\"{int(abs_vals[i, j]):,}\",\n",
    "                ha=\"center\", va=\"center\", fontsize=13, fontweight=\"bold\", color=color)\n",
    "plt.colorbar(im, ax=ax, shrink=0.8)\n",
    " \n",
    "# Heatmap with relative values\n",
    "ax = axes4[1]\n",
    "im2 = ax.imshow(rel_vals, cmap=\"Oranges\", aspect=\"auto\", vmin=0, vmax=1)\n",
    "ax.set_xticks([0, 1]); ax.set_xticklabels(col_labels)\n",
    "ax.set_yticks([0, 1]); ax.set_yticklabels(row_labels)\n",
    "ax.set_xlabel(\"Nächster Sprecher\"); ax.set_ylabel(\"Sprecher\")\n",
    "ax.set_title(\"Relative Häufigkeit\\n(Anteil je Geschlecht)\")\n",
    "for i in range(2):\n",
    "    for j in range(2):\n",
    "        color = \"white\" if rel_vals[i, j] > 0.6 else \"black\"\n",
    "        ax.text(j, i, f\"{rel_vals[i, j]:.1%}\",\n",
    "                ha=\"center\", va=\"center\", fontsize=13, fontweight=\"bold\", color=color)\n",
    "plt.colorbar(im2, ax=ax, shrink=0.8)\n",
    " \n",
    " \n",
    "plt.tight_layout()\n",
    "plt.savefig(\"output/interaction_analysis_gender.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show() "
