    "#Stopwords\n",
    "stopwords = set()\n",
    "with open(\"../data/german_stopwords_full.txt\", \"r\", encoding=\"utf-8\") as f:\n",
    "    stopwords.update([w.lower() for w in f.read().splitlines()\n",
    "                      if w and not w.startswith(\"//\")])\n",
    "    \n",
    "#identifying tokens (simpler model of de_core_news_lg)\n",
    "nlp = spacy.load(\"de_core_news_lg\", disable=[\"ner\", \"parser\", \"tok2vec\", \"morphologizer\", \"senter\"])\n",
    "nlp.add_pipe(\"sentencizer\")\n",
    " \n",
    "texts = scriptdata[\"Text\"].tolist()\n",
    "sentences_all, tokens_all = [], []\n",
    " \n",
    "for doc in nlp.pipe(texts, batch_size=BATCH_SIZE, n_process=1):\n",
    "    sentences_all.append([sent.text.strip() for sent in doc.sents])\n",
    "    tokens_all.append([\n",
    "        token.lemma_.lower()\n",
    "        for token in doc\n",
    "        if token.is_alpha and token.lemma_.lower() not in stopwords\n",
    "    ])\n",
    " \n",
    "scriptdata[\"sentences\"] = sentences_all\n",
    "scriptdata[\"tokens\"] = tokens_all\n",
    "scriptdata = scriptdata.explode(\"sentences\")\n",
    "scriptdata = scriptdata[~scriptdata[\"sentences\"].isna()].copy()\n",
    "scriptdata = scriptdata.drop(columns=[\"Text\"])"
   ]
  },
