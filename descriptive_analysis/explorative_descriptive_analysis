    "# vocabulary-analysis with additional stopwords\n",
    "\n",
    "custom_stopwords = {\"bob\", \"peter\", \"mrs\", \"justus\", \"genau\", \"aha\", \"ähm\", \"sir\", \"jonas\", \"eigentlich\", \"mister\", \"hallo\", \"mr\", \"och\"}\n",
    "\n",
    "for word in custom_stopwords:\n",
    "    counter_m.pop(word, None)\n",
    "    counter_f.pop(word, None)\n",
    "\n",
    "scriptdata[\"tokens\"] = scriptdata[\"tokens\"].apply(\n",
    "    lambda toks: [t for t in toks if t not in custom_stopwords]\n",
    ")\n",
    "\n",
    "total_m = sum(counter_m.values())\n",
    "total_f = sum(counter_f.values())\n",
    "unique_m = len(counter_m)\n",
    "unique_f = len(counter_f)\n",
    "\n",
    "# vocabulary-analysis\n",
    "\n",
    " \n",
    "def get_all_tokens(df, gender_label):\n",
    "    return [tok for toks in df[df[\"gender\"] == gender_label][\"tokens\"] for tok in toks]\n",
    " \n",
    "def msttr(tokens, segment_size=1000):\n",
    "    segments = [tokens[i:i+segment_size] for i in range(0, len(tokens), segment_size)]\n",
    "    segments = [s for s in segments if len(s) == segment_size]\n",
    "    if not segments:\n",
    "        return float(\"nan\")\n",
    "    return np.mean([len(set(s)) / len(s) for s in segments])\n",
    " \n",
    "def vocab_stats(tokens, counter, label):\n",
    "    total = len(tokens)\n",
    "    unique = len(counter)\n",
    "    ttr = unique / total if total else 0\n",
    "    ms = msttr(tokens, segment_size=1000)\n",
    "    print(f\"\\n── {label} ──────────────────────────────\")\n",
    "    print(f\"  Tokens: {total:>10,}\")\n",
    "    print(f\"  Types: {unique:>10,}\")\n",
    "    print(f\"  TTR: {ttr:>10.4f}\")\n",
    "    print(f\"  MSTTR: {ms:>10.4f}\")\n",
    "    return {\"label\": label, \"total\": total, \"unique\": unique,\n",
    "            \"ttr\": ttr, \"msttr\": ms,\n",
    "           }\n",
    " \n",
    "tokens_m = get_all_tokens(scriptdata, \"m\")\n",
    "tokens_f = get_all_tokens(scriptdata, \"f\")\n",
    " \n",
    "stats_m = vocab_stats(tokens_m, counter_m, \"Männliche Figuren\")\n",
    "stats_f = vocab_stats(tokens_f, counter_f, \"Weibliche Figuren\")\n",
    " \n",
    "# Visualization\n",
    "metrics = {\n",
    "    \"TTR\": (\"ttr\",       \"Ratio\"),\n",
    "    \"MSTTR\": (\"msttr\",     \"Ø TTR pro 1.000\")\n",
    "}\n",
    " \n",
    "fig3, axes3 = plt.subplots(1, 2, figsize=(18, 5))\n",
    "fig3.suptitle(\"Wortschatzvergleich nach Geschlecht\",\n",
    "              fontsize=15, fontweight=\"bold\")\n",
    " \n",
    "for ax, (metric_label, (key, ylabel)) in zip(axes3, metrics.items()):\n",
    "    vals = [stats_m[key], stats_f[key]]\n",
    "    bars = ax.bar([\"Männlich\", \"Weiblich\"], vals,\n",
    "                  color=[COLOR_M, COLOR_F], edgecolor=\"white\", width=0.5)\n",
    "    ax.bar_label(bars, fmt=\"{:.4f}\", padding=4, fontsize=10, fontweight=\"bold\")\n",
    "    ax.set_title(metric_label, fontsize=12)\n",
    "    ax.set_ylabel(ylabel, fontsize=9)\n",
    "    ax.set_ylim(0, max(vals) * 1.2)\n",
    "    ax.spines[[\"top\", \"right\"]].set_visible(False)\n",
    " \n",
    "plt.tight_layout()\n",
    "plt.savefig(\"output/vocabulary_richness_gender.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()"
