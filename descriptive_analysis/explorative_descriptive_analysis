    "# counter of the tokens by gender\n",
    "def aggregate_tokens(df, gender_label):\n",
    "    subset = df[df[\"gender\"] == gender_label][\"tokens\"]\n",
    "    all_tokens = [tok for token_list in subset for tok in token_list]\n",
    "    return Counter(all_tokens)\n",
    "\n",
    "counter_m = aggregate_tokens(scriptdata, \"m\")\n",
    "counter_f = aggregate_tokens(scriptdata, \"f\")\n",
    "\n",
    "print(counter_m.most_common(50))\n",
    "print(counter_f.most_common(50))"
